{
  "manifest_version": 3,
  "name": "NextGenDM Interceptor",
  "version": "1.0",
  "description": "Intercepts browser downloads and forwards them to the NextGenDM desktop application.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "host_permissions": [
    "http://localhost:14200/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
