# ============================================
# NextGenDM .gitignore
# Rust + Tauri v2 + Node.js + React + TypeScript
# ============================================

# ---------- Rust / Cargo ----------
/target/
src-tauri/target/
**/*.rs.bk
# NOTE: Cargo.lock IS committed (binary project)

# ---------- Tauri ----------
src-tauri/gen/
WixTools/

# ---------- Node.js ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------- Build Output ----------
/dist/
/build/
/out/

# ---------- TypeScript ----------
*.tsbuildinfo

# ---------- Vite ----------
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ---------- Environment ----------
.env
.env.*
!.env.example

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# ---------- Testing / Coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- Database (runtime) ----------
*.db
*.db-journal
*.db-wal
*.db-shm

# ---------- Logs ----------
logs/
*.log

# ---------- Package Managers ----------
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ---------- Misc ----------
*.tgz
.cache/
.parcel-cache/
